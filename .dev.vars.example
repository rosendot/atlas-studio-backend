# Local development secrets for `wrangler dev --remote`.
# Copy to `.dev.vars` (gitignored) and fill in real values.
#
# IMPORTANT: local dev runs against production D1 + R2, so these secrets
# should be the SAME values as production. Don't generate new ones — paste
# the production secrets from 1Password / the Cloudflare dashboard.
#
# Production secrets are set via Cloudflare dashboard → Workers →
# atlas-studio-backend → Settings → Variables and Secrets.

# 32+ byte secret signing session cookies. Must match production exactly,
# or sessions created locally won't validate when you hit production.
BETTER_AUTH_SECRET=paste-production-value-from-1password

# Resend API key for transactional email. Local dev sends real emails.
RESEND_API_KEY=re_paste_production_value

# Better Auth user.id of the admin (you). Set after signing up at least once.
# Leave blank for first-time setup before you have an account.
ADMIN_UID=

# Optional: Sign in with Google. Skip unless OAuth is wired up.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
